# Site URL for canonical links, Open Graph, sitemap, and JSON-LD (defaults to https://www.ftwagency.ai).
# NEXT_PUBLIC_SITE_URL=https://www.ftwagency.ai

# Mapbox — interactive maps on /locations and city hub pages (domain-restrict in Mapbox dashboard).
# Falls back to a static pin map when unset.
# NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_public_token

# Web3Forms — strategy call / contact form submissions (optional override)
# NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=5e9ddac9-b0cb-4581-bc77-e059ca774e24
