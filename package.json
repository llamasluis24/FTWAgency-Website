{
  "name": "ftw-agency-website",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "lsof -ti :3000 | xargs kill -9 2>/dev/null || true; next dev --port 3000",
    "dev:clean": "lsof -ti :3000 | xargs kill -9 2>/dev/null || true; rm -rf .next && next dev --port 3000",
    "build": "next build",
    "build:clean": "rm -rf .next && next build",
    "start": "next start",
    "lint": "next lint",
    "validate:locations": "npx tsx scripts/validate-locations.ts"
  },
  "dependencies": {
    "framer-motion": "^12.40.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.17.0",
    "next": "^15.5.19",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3"
  }
}
